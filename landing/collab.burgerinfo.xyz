server {
    listen 80;
    server_name collab.burgerinfo.xyz;
    return 301 https://collab.burgerinfo.xyz$request_uri;
}

server {
    listen 443 ssl http2;
    server_name collab.burgerinfo.xyz;

    ssl_certificate /etc/letsencrypt/live/collab.burgerinfo.xyz/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/collab.burgerinfo.xyz/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;

    root /var/www/collab.burgerinfo.xyz;
    index index.html;

    location / {
        try_files $uri $uri/ =404;
    }
}
